{
  "expo": {
    "name": "GroupMatchmakerApp",
    "slug": "GroupMatchmakerApp",
    "scheme": "groupmatchmakerapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marcz2007.GroupMatchmakerApp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.marcz2007.GroupMatchmakerApp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "group-matchmaker-app-web.vercel.app",
              "pathPrefix": "/event/"
            },
            {
              "scheme": "https",
              "host": "group-matchmaker-app-web.vercel.app",
              "pathPrefix": "/group/invite/"
            },
            {
              "scheme": "https",
              "host": "group-matchmaker-app-web.vercel.app",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "876034cd-48d2-4305-8754-741f1efd638f"
      }
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you set a profile picture."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.537397372254-2gruob2oguontpaojcm52uel30bnecb5"
        }
      ]
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/876034cd-48d2-4305-8754-741f1efd638f"
    }
  },
  "_iosUniversalLinksTemplate": {
    "_comment": "PARKED: iOS Universal Links config. Activate this when you pay for the Apple Developer account. Steps: (1) Copy `associatedDomains` into expo.ios above (as a sibling of `bundleIdentifier`). (2) Set APPLE_TEAM_ID on Vercel (Settings → Environment Variables). Optionally set APPLE_BUNDLE_ID if you ever change the bundle. (3) Redeploy the web app so /.well-known/apple-app-site-association starts serving the JSON (route handler at packages/web/src/app/api/well-known/apple-app-site-association/route.ts). (4) Run `eas build --platform ios --profile production` — associatedDomains is a native entitlement, so an OTA update via expo-updates WILL NOT pick it up, you need a fresh native build submitted to TestFlight/App Store. (5) Wait a few minutes after the new build is installed on a device — iOS fetches the AASA file asynchronously the first time. This root-level key is ignored by Expo's config loader since it only reads the `expo` object.",
    "associatedDomains": [
      "applinks:group-matchmaker-app-web.vercel.app"
    ]
  }
}
